generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// -------------------------------------
// Usuarios y Perfiles (Supabase Auth extensions)
// -------------------------------------
model Profile {
  id        String   @id @default(uuid())
  auth_id   String   @unique // ID del usuario en auth.users de Supabase
  email     String   @unique
  nombre    String?
  rol       Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tareasAsignadas       Tarea[]               @relation("TareasAsignadas")
  hitosAsignados        HitoProyecto[]
  tareasAdministrativas TareaAdministrativa[]
  actividades_crm       ActividadCRM[]

  app_role_id String?
  app_role    AppRole? @relation(fields: [app_role_id], references: [id], onDelete: SetNull)

  recordatorios Recordatorio[]
}

model AppRole {
  id          String   @id @default(uuid())
  nombre      String   @unique
  descripcion String?
  permisos    Json     // Array of module permission strings
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  perfiles    Profile[]
}

enum Role {
  SUPERADMIN
  ADMIN
  USER
  MANAGER
}

// -------------------------------------
// Módulo de CRM (Ventas y Clientes)
// -------------------------------------
model Cliente {
  id        String        @id @default(uuid())
  nombre    String
  empresa   String?
  email     String?
  telefono  String?
  rfc_taxid String?
  fuente    String?       // "Meta Ads", "Google Ads", "WordPress", "Manual", etc.
  notas     String?       // Metadata adicional: campaña, ad set, etc.
  estatus   ClienteStatus @default(LEAD)
  
  // Datos Fiscales / Dirección
  razon_social String?
  regimen_fiscal String?
  codigo_postal String?
  direccion    String?
  colonia      String?
  ciudad       String?
  
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  oportunidades Oportunidad[]
  proyectos     Proyecto[]
  cotizaciones  Cotizacion[]
  facturas      Factura[]
  tareas        Tarea[]
  transacciones_freq TransaccionFrecuente[]
  actividades_crm ActividadCRM[]
}

enum ClienteStatus {
  LEAD
  ACTIVO
  INACTIVO
}

model Oportunidad {
  id             String           @id @default(uuid())
  titulo         String
  valor_estimado Float            @default(0)
  etapa          EtapaOportunidad @default(PROSPECTO)
  cliente_id     String
  cliente        Cliente          @relation(fields: [cliente_id], references: [id], onDelete: Cascade)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  cotizaciones Cotizacion[]
}

enum EtapaOportunidad {
  PROSPECTO
  CONTACTADO
  NEGOCIACION
  GANADO
  PERDIDO
}

model ActividadCRM {
  id           String             @id @default(uuid())
  cliente_id   String
  cliente      Cliente            @relation(fields: [cliente_id], references: [id], onDelete: Cascade)
  tipo         TipoActividadCRM
  titulo       String?
  descripcion  String?            @db.Text
  fecha        DateTime           @default(now())
  usuario_id   String?
  usuario      Profile?           @relation(fields: [usuario_id], references: [id], onDelete: SetNull)
  metadata     Json?              // Detalles extra (links de meet, id correo, duración llamada, etc)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
}

enum TipoActividadCRM {
  NOTA
  CORREO
  LLAMADA
  REUNION
  SISTEMA
}

// -------------------------------------
// Módulo de Tareas
// -------------------------------------
model Encargado {
  id        String   @id @default(uuid())
  nombre    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tareas Tarea[]
}

enum Prioridad {
  BAJA
  MEDIA
  ALTA
  URGENTE
}

enum CategoriaTarea {
  ADMINISTRATIVA
  OPERATIVA
  VENTAS
  MARKETING
  OTRO
}

model Tarea {
  id           String         @id @default(uuid())
  titulo       String
  descripcion  String? // Notas adicionales o detalle
  fecha_limite DateTime?
  estatus      TareaStatus    @default(PENDIENTE)
  prioridad    Prioridad      @default(MEDIA)
  categoria    CategoriaTarea @default(OTRO)
  orden        Int            @default(0) // Para Drag and Drop
  is_focus     Boolean        @default(false)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  proyecto_id String?
  proyecto    Proyecto? @relation(fields: [proyecto_id], references: [id], onDelete: SetNull)

  cliente_id String?
  cliente    Cliente? @relation(fields: [cliente_id], references: [id], onDelete: SetNull)

  encargados Encargado[] // Relación N:M implícita

  comentarios ComentarioTarea[]

  // Opcional, mantenemos compatibilidad con el sistema de Profile anterior por si acaso
  asignado_a_id String?
  asignado_a    Profile? @relation("TareasAsignadas", fields: [asignado_a_id], references: [id])

  recordatorios TareaRecordatorio[]
}

model ComentarioTarea {
  id        String   @id @default(uuid())
  texto     String
  createdAt DateTime @default(now())

  tarea_id String
  tarea    Tarea  @relation(fields: [tarea_id], references: [id], onDelete: Cascade)
}

enum TareaStatus {
  PENDIENTE
  EN_CURSO
  ON_HOLD
  COMPLETADA
  CANCELADA
}

// -------------------------------------
// Módulo de Recordatorios
// -------------------------------------
model Recordatorio {
  id                 String   @id @default(uuid())
  fecha_creacion     DateTime @default(now())
  descripcion        String   @db.Text
  fecha_recordatorio DateTime
  estatus            RecordatorioStatus @default(PENDIENTE)
  
  tareas_asociadas   TareaRecordatorio[]
  
  usuario_id         String?
  usuario            Profile? @relation(fields: [usuario_id], references: [id], onDelete: SetNull)

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model TareaRecordatorio {
  recordatorio_id String
  recordatorio    Recordatorio @relation(fields: [recordatorio_id], references: [id], onDelete: Cascade)
  tarea_id        String
  tarea           Tarea        @relation(fields: [tarea_id], references: [id], onDelete: Cascade)

  @@id([recordatorio_id, tarea_id])
}

enum RecordatorioStatus {
  PENDIENTE
  ENVIADO
  COMPLETADO
}

// -------------------------------------
// Módulo de Proyectos (Kanban / Project Plan)
// -------------------------------------
model Proyecto {
  id           String         @id @default(uuid())
  nombre       String
  descripcion  String?
  estado       ProyectoStatus @default(ACTIVO)
  fecha_inicio DateTime?
  fecha_fin    DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  cliente_id String?
  cliente    Cliente? @relation(fields: [cliente_id], references: [id])

  hitos        HitoProyecto[]
  cotizaciones Cotizacion[]
  tareas       Tarea[]
  cuentas_por_pagar CuentaPorPagar[]
  movimientos       MovimientoFinanciero[]
}

enum ProyectoStatus {
  PLANIFICACION
  ACTIVO
  PAUSADO
  COMPLETADO
}

model HitoProyecto {
  id             String     @id @default(uuid())
  titulo         String
  descripcion    String?
  fecha_limite   DateTime?
  estatus        HitoStatus @default(PENDIENTE)
  proyecto_id    String
  proyecto       Proyecto   @relation(fields: [proyecto_id], references: [id], onDelete: Cascade)
  responsable_id String?
  responsable    Profile?   @relation(fields: [responsable_id], references: [id])
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

enum HitoStatus {
  PENDIENTE
  EN_CURSO
  COMPLETADO
}

model Cotizacion {
  id                String           @id @default(uuid())
  folio             String           @unique @default(cuid())
  monto             Float
  estatus           CotizacionStatus @default(BORRADOR)
  fecha_vencimiento DateTime?

  proyecto_id String?
  proyecto    Proyecto? @relation(fields: [proyecto_id], references: [id], onDelete: SetNull)

  oportunidad_id String?
  oportunidad    Oportunidad? @relation(fields: [oportunidad_id], references: [id], onDelete: SetNull)

  cliente_id String?
  cliente    Cliente? @relation(fields: [cliente_id], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  facturas Factura[]
  items    CotizacionItem[]
}

enum CotizacionStatus {
  BORRADOR
  ENVIADA
  ACEPTADA
  RECHAZADA
}

// -------------------------------------
// Módulo de Facturación
// -------------------------------------
model Factura {
  id                String        @id @default(uuid())
  folio             String        @unique
  fecha_emision     DateTime      @default(now())
  fecha_vencimiento DateTime?
  monto_total       Float
  descripcion       String?       @db.Text
  categoria         String?
  estatus           FacturaStatus @default(PENDIENTE)

  // CFDI 4.0 (Facturapi)
  requiere_cfdi     Boolean       @default(false)
  estatus_cfdi      EstatusCFDI?
  
  // Exportación / Facturas USA
  es_usa            Boolean       @default(false)
  numero_usa        Int?
  monto_mxn_estimado Float?
  detalle_horas     String?       @db.Text
  numero_orden      String?
  folio_fiscal      String?       // Folio interno (ej. FAC-MOV-510)
  
  // Facturas MX (Solicitud de Pago)
  es_mx             Boolean       @default(false)
  numero_mx         Int?
  mes_servicio      String?
  tipo_servicio     String?
  plataformas       String?
  facturapi_id      String?       // ID de la factura en Facturapi
  uuid_sat          String?       // UUID oficial del SAT
  url_pdf           String?
  url_xml           String?
  fecha_facturado   DateTime?
  forma_pago        String?       // 01, 03, etc.
  metodo_pago       MetodoPagoCFDI? // PUE o PPD
  uso_cfdi          String?       // G03, P01, etc.

  cliente_id String
  cliente    Cliente @relation(fields: [cliente_id], references: [id], onDelete: Cascade)

  cotizacion_id String?
  cotizacion    Cotizacion? @relation(fields: [cotizacion_id], references: [id], onDelete: SetNull)

  linea_producto_id String?
  linea_producto    LineaProducto? @relation(fields: [linea_producto_id], references: [id], onDelete: SetNull)

  monto_pagado      Float          @default(0)
  pagos_parciales   PagoParcial[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum FacturaStatus {
  PENDIENTE
  PAGADA_PARCIALMENTE
  PAGADA
  VENCIDA
  CANCELADA
}

enum EstatusCFDI {
  EN_BORRADOR
  FACTURADO
  CANCELADO
}

enum MetodoPagoCFDI {
  PUE // Pago en una sola exhibición
  PPD // Pago en parcialidades o diferido
}

// -------------------------------------
// Módulo de Cuentas por Pagar (Proveedores)
// -------------------------------------
model Proveedor {
  id                String   @id @default(uuid())
  nombre            String
  empresa           String?
  rfc               String?
  correo            String?
  telefono          String?
  direccion         String?
  notas             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  cuentas_por_pagar CuentaPorPagar[]
  transacciones_freq TransaccionFrecuente[]
}

model CuentaPorPagar {
  id                String        @id @default(uuid())
  folio             String        @unique
  fecha_emision     DateTime      @default(now())
  fecha_vencimiento DateTime?
  monto_total       Float
  descripcion       String?       @db.Text
  categoria         String?
  estatus           FacturaStatus @default(PENDIENTE)

  proveedor_id      String
  proveedor         Proveedor     @relation(fields: [proveedor_id], references: [id], onDelete: Cascade)

  monto_pagado      Float         @default(0)
  pagos_parciales   PagoParcial[]

  proyecto_id       String?
  proyecto          Proyecto?     @relation(fields: [proyecto_id], references: [id], onDelete: SetNull)

  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

// -------------------------------------
// Pagos Parciales
// -------------------------------------
model PagoParcial {
  id                 String   @id @default(uuid())
  monto              Float
  fecha              DateTime @default(now())
  metodo_pago        String?
  referencia         String?
  
  factura_id         String?
  factura            Factura? @relation(fields: [factura_id], references: [id], onDelete: Cascade)
  
  cuenta_por_pagar_id String?
  cuenta_por_pagar   CuentaPorPagar? @relation(fields: [cuenta_por_pagar_id], references: [id], onDelete: Cascade)
  
  movimiento_id      String? // Reference to the MovimientoFinanciero created
  
  // Complemento de Pago CFDI (REP)
  requiere_complemento Boolean @default(false)
  complemento_id       String? // Facturapi Receipt ID
  url_pdf_complemento  String?
  url_xml_complemento  String?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

// -------------------------------------
// Módulo Financiero / Administrativo
// -------------------------------------
model MovimientoFinanciero {
  id                String            @id @default(uuid())
  fecha             DateTime
  descripcion       String
  monto             Float
  monto_usd         Float?
  tipo_flujo        TipoFlujo
  sentido           SentidoMovimiento
  origen            String
  es_fiscal         Boolean           @default(true)
  categoria_ingreso String?
  categoria_egreso  String?

  linea_producto_id String?
  linea_producto    LineaProducto? @relation(fields: [linea_producto_id], references: [id], onDelete: SetNull)

  proyecto_id       String?
  proyecto          Proyecto?      @relation(fields: [proyecto_id], references: [id], onDelete: SetNull)

  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
}

enum TipoFlujo {
  OPERATIVO
  INVERSION
  FINANCIAMIENTO
}

enum SentidoMovimiento {
  INGRESO
  EGRESO
}

model TareaAdministrativa {
  id             String         @id @default(uuid())
  tipo           TipoTareaAdmin
  entidad        String // "Juan", "Pedro", etc.
  monto          Float
  estatus        TareaStatus    @default(PENDIENTE)
  historial      String? // Notas adicionales
  responsable_id String?
  responsable    Profile?       @relation(fields: [responsable_id], references: [id])
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

enum TipoTareaAdmin {
  CUENTA_POR_COBRAR
  CUENTA_POR_PAGAR
}

// -------------------------------------
// Módulo de Configuración / Integraciones
// -------------------------------------
model Integracion {
  id         String   @id @default(uuid())
  proveedor  String   @unique // Ej: "SMTP_CORREO", "FACEBOOK_ADS"
  config     Json     // Configuraciones específicas
  activa     Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// -------------------------------------
// Módulo de Catálogo y Líneas de Productos
// -------------------------------------
model LineaProducto {
  id          String   @id @default(uuid())
  nombre      String
  descripcion String?
  activa      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  productos   ProductoServicio[]
  movimientos MovimientoFinanciero[]
  facturas    Factura[]
}

model ProductoServicio {
  id                String   @id @default(uuid())
  nombre            String
  descripcion       String?
  precio_base       Float?
  linea_producto_id String
  linea_producto    LineaProducto @relation(fields: [linea_producto_id], references: [id], onDelete: Cascade)
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  cotizacionItems   CotizacionItem[]
}

model CotizacionItem {
  id              String   @id @default(uuid())
  cotizacion_id   String
  cotizacion      Cotizacion @relation(fields: [cotizacion_id], references: [id], onDelete: Cascade)
  producto_id     String?
  producto        ProductoServicio? @relation(fields: [producto_id], references: [id], onDelete: SetNull)
  descripcion     String
  cantidad        Int      @default(1)
  precio_unitario Float
  monto_total     Float
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// -------------------------------------
// Transacciones Frecuentes (Favoritos)
// -------------------------------------
model TransaccionFrecuente {
  id                String   @id @default(uuid())
  tipo              TipoTransaccionFrecuente // CXC o CXP
  titulo            String   // Ej: "Renta de Oficina" o "Retainer Cliente X"
  monto             Float
  descripcion       String?
  
  cliente_id        String?
  cliente           Cliente? @relation(fields: [cliente_id], references: [id], onDelete: SetNull)

  proveedor_id      String?
  proveedor         Proveedor? @relation(fields: [proveedor_id], references: [id], onDelete: SetNull)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

enum TipoTransaccionFrecuente {
  CXC
  CXP
}
